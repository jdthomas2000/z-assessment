  "scripts": {
    "postinstall": "npm install --prefix frontend/template && npm install --prefix backend",
    "db:init": "cd backend && npx knex migrate:rollback --knexfile db/knexfile.js && npx knex migrate:latest --knexfile db/knexfile.js && npx knex seed:run --knexfile db/knexfile.js",
    "start-frontend": "cd frontend/template && npm run dev",
    "start-backend": "cd backend && npm run dev",
    "dev": "concurrently \"npm run start-frontend\" \"npm run start-backend\""
